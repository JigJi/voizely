# Voizely frontend_auth — copy this to .env and fill in values
# .env is gitignored, never commit it

HOST=127.0.0.1
PORT=8810

# Backend (Tailscale Funnel public URL)
BACKEND_PUBLIC_URL=https://voizely-backend.tailb8d083.ts.net
BACKEND_TIMEOUT=10.0

# Shared secret with backend — must match backend's .env INTERNAL_API_KEY
# Get this value from the backend host's .env file
INTERNAL_API_KEY=

LOG_DIR=./logs

# AD configs — defaults match smart_e_gp, only override if needed
# AD_APPWORKS_SERVER=172.20.0.101
# AD_APPWORKS_DOMAIN=ais.local
# AD_APPWORKS_EMAIL_SUFFIX=appworks.co.th
# AD_APPWORKS_BASE=DC=ais,DC=local

# AD_IWIRED_SERVER=192.168.0.14
# AD_IWIRED_DOMAIN=iwired.co.th
# AD_IWIRED_EMAIL_SUFFIX=iwired.co.th
# AD_IWIRED_BASE=DC=iwired,DC=co,DC=th
